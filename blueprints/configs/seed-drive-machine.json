{
  "id": "drive-machine",
  "name": "The Drive Machine",
  "description": "Three competing drives (safety, belonging, competence) generate emotions that bias action selection",
  "version": 1,
  "primitives": [
    {
      "id": "safety-drive",
      "domain": "motivation",
      "description": "Avoid harm, maintain predictability. Produces fear, anxiety, relief.",
      "weights": { "stimulusIntensity": 0.8, "stimulusNovelty": 0.3, "personalRelevance": 0.6, "socialPresence": -0.1, "threatLevel": 0.9, "choicePresent": 0.1, "arousal": 0.4, "neuroticism": 0.5, "openness": -0.2, "agreeableness": 0.0 },
      "emotionOutput": "fear/anxiety",
      "arousalDelta": 0.5,
      "behaviorBias": "avoids threat, freezes, or escapes before conscious evaluation",
      "rootCauseType": "evolutionary",
      "relatesTo": ["appraisal", "emotion-signal"],
      "amplifies": ["emotion-signal"],
      "inhibits": ["competence-drive"]
    },
    {
      "id": "belonging-drive",
      "domain": "social",
      "description": "Need for social connection and group acceptance. Produces shame, pride, loneliness.",
      "weights": { "stimulusIntensity": 0.2, "stimulusNovelty": 0.1, "personalRelevance": 0.4, "socialPresence": 0.9, "threatLevel": 0.2, "choicePresent": 0.0, "arousal": 0.1, "neuroticism": 0.2, "openness": 0.0, "agreeableness": 0.6 },
      "emotionOutput": "social-anxiety/shame",
      "arousalDelta": 0.2,
      "behaviorBias": "conforms to group, monitors social cues, maintains harmony",
      "rootCauseType": "evolutionary",
      "relatesTo": ["appraisal", "emotion-signal", "safety-drive"],
      "amplifies": ["emotion-signal"],
      "inhibits": []
    },
    {
      "id": "competence-drive",
      "domain": "motivation",
      "description": "Need to master the environment and feel capable. Produces frustration, satisfaction, curiosity.",
      "weights": { "stimulusIntensity": 0.1, "stimulusNovelty": 0.5, "personalRelevance": 0.5, "socialPresence": 0.0, "threatLevel": -0.2, "choicePresent": 0.7, "arousal": -0.1, "neuroticism": -0.2, "openness": 0.6, "agreeableness": 0.0 },
      "emotionOutput": "curiosity/frustration",
      "arousalDelta": 0.1,
      "behaviorBias": "engages with challenge, seeks mastery, persists or lowers standards",
      "rootCauseType": "structural",
      "relatesTo": ["appraisal", "energy-budget"],
      "amplifies": [],
      "inhibits": ["safety-drive"]
    },
    {
      "id": "appraisal",
      "domain": "cognition",
      "description": "Rapid evaluation of situation against drives. Uses heuristics under pressure, creating biases.",
      "weights": { "stimulusIntensity": 0.5, "stimulusNovelty": 0.5, "personalRelevance": 0.7, "socialPresence": 0.3, "threatLevel": 0.4, "choicePresent": 0.4, "arousal": 0.3, "neuroticism": 0.3, "openness": 0.1, "agreeableness": 0.1 },
      "emotionOutput": "alertness",
      "arousalDelta": 0.15,
      "behaviorBias": "evaluates and classifies stimulus, routes to relevant drive",
      "rootCauseType": "structural",
      "relatesTo": ["safety-drive", "belonging-drive", "competence-drive"],
      "amplifies": ["safety-drive", "belonging-drive", "competence-drive"],
      "inhibits": []
    },
    {
      "id": "energy-budget",
      "domain": "cognition",
      "description": "Regulates effort based on expected return. Low energy = habits and shortcuts.",
      "weights": { "stimulusIntensity": -0.3, "stimulusNovelty": -0.2, "personalRelevance": 0.3, "socialPresence": -0.1, "threatLevel": -0.3, "choicePresent": 0.4, "arousal": -0.5, "neuroticism": -0.1, "openness": 0.2, "agreeableness": 0.0 },
      "emotionOutput": "fatigue/boredom",
      "arousalDelta": -0.2,
      "behaviorBias": "takes easy path, satisfices, defaults to habit",
      "rootCauseType": "structural",
      "relatesTo": ["appraisal", "competence-drive"],
      "amplifies": [],
      "inhibits": ["competence-drive"]
    },
    {
      "id": "emotion-signal",
      "domain": "emotion",
      "description": "Drives produce emotions as signals to action-selection. Fear=escape, shame=conform, curiosity=explore.",
      "weights": { "stimulusIntensity": 0.4, "stimulusNovelty": 0.3, "personalRelevance": 0.6, "socialPresence": 0.2, "threatLevel": 0.5, "choicePresent": 0.1, "arousal": 0.5, "neuroticism": 0.4, "openness": 0.1, "agreeableness": 0.2 },
      "emotionOutput": "varies by dominant drive",
      "arousalDelta": 0.3,
      "behaviorBias": "biases action toward dominant drive's preferred response",
      "rootCauseType": "structural",
      "relatesTo": ["safety-drive", "belonging-drive", "competence-drive"],
      "amplifies": [],
      "inhibits": []
    },
    {
      "id": "action-selection",
      "domain": "behavior",
      "description": "Picks behavior by weighing drive signals and energy. Strongest drive-emotion wins.",
      "weights": { "stimulusIntensity": 0.3, "stimulusNovelty": 0.1, "personalRelevance": 0.4, "socialPresence": 0.2, "threatLevel": 0.3, "choicePresent": 0.5, "arousal": 0.2, "neuroticism": 0.1, "openness": 0.1, "agreeableness": 0.1 },
      "emotionOutput": "resolved",
      "arousalDelta": -0.1,
      "behaviorBias": "executes the strongest drive-emotion combination as behavior",
      "rootCauseType": "structural",
      "relatesTo": ["emotion-signal", "energy-budget"],
      "amplifies": [],
      "inhibits": []
    }
  ]
}
